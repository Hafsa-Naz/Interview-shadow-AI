OPENAI_API_KEY=your_openai_api_key
DEMO_MODE=false
FIREBASE_AUTH_REQUIRED=false
# In production, set this to a Firebase Admin SDK service-account JSON-file path.
FIREBASE_SERVICE_ACCOUNT_PATH=
